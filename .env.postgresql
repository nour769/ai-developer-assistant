"""
PostgreSQL Configuration Template

Production: .env.postgresql

Copie ce fichier en .env.postgresql et remplis les valeurs de production.
Commande pour charger: 
  - Linux/Mac: source .env.postgresql
  - Windows PowerShell: Get-Content .env.postgresql | ForEach-Object { $name, $value = $_ -split '='; Set-Item "env:$name" $value }
"""

# === Database Configuration ===
# Utilise PostgreSQL au lieu de SQLite
USE_POSTGRES=true

# URL de connexion PostgreSQL
# Format: postgresql://username:password@host:port/database
# Exemples:
# - Local: postgresql://postgres:password@localhost:5432/ai_assistant
# - Cloud (AWS RDS): postgresql://admin:password@ai-assistant.xxxxx.us-east-1.rds.amazonaws.com:5432/ai_assistant
# - Cloud (Azure): postgresql://admin@servername:password@servername.postgres.database.azure.com:5432/ai_assistant
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ai_assistant

# === LLM Configuration ===
GROQ_API_KEY=gsk_YOUR_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# === Embeddings ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Vector Store ===
VECTORSTORE_PATH=data/vectorstore

# === Optional: Production Settings ===
# LOG_LEVEL=info
# WORKERS=4  # Nombre de workers Uvicorn
# ENVIRONMENT=production
